rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /catalog_metadata/{countryCode} {
      allow read: if true;
      allow write: if false;
    }

    match /countries/{countryCode}/products/{productId} {
      allow read: if resource.data.active == true;
      allow write: if false;
    }
  }
}
